# Database (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:npg_xxxxx@ep-xxxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# JWT Configuration
JWT_SECRET=sua_chave_secreta_super_segura_aqui_nathy_salao_2025
JWT_EXPIRATION=7d

# Server
NODE_ENV=development
PORT=3001

# Sentry (Error Tracking & Performance Monitoring)
# Optional: Get from https://sentry.io
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Redis (Caching)
# Optional: Only needed if Redis is configured
REDIS_URL=redis://localhost:6379

# App Configuration
APP_NAME=Salão Nathy
APP_VERSION=1.0.0

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
