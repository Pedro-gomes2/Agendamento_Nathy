# ===== DATABASE (Supabase PostgreSQL) =====
# Para Supabase: https://supabase.com
# Host: Dashboard → Settings → Database → Host
DATABASE_HOST=db.xxxxx.supabase.co
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=sua_senha_aqui_nunca_commit
DATABASE_NAME=postgres
DATABASE_SSL=true

# ===== DATABASE OPTIONS =====
# Development: true (sincroniza schema automaticamente)
# Production: false (usa migrations)
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# ===== AUTHENTICATION =====
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_aleatoria_super_segura_de_64_caracteres
JWT_EXPIRATION=7d

# ===== SERVER =====
# development, production, staging
NODE_ENV=development
PORT=3001

# ===== CACHE (Redis - opcional) =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== MONITORING (Sentry - opcional) =====
# SENTRY_DSN=https://seu_sentry_dsn@sentry.io/project_id
